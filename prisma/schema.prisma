// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Employee {
  id             String             @id @default(uuid())
  mobileNumber   String             @unique // Serving as the unique login username
  passwordHash   String
  role           String             // "ADMIN" | "TECHNICIAN"
  fullName       String?
  contactPhone   String?            // Optional contact phone
  employeeNumber String?            @unique // Unique Employee ID/Number
  email          String?            // Employee Email ID
  isActive       Boolean            @default(true)
  assignments    TicketAssignment[]
  history        TicketHistory[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
}

model Customer {
  id             String             @id @default(uuid())
  companyName    String?
  contactName    String
  primaryPhone   String
  secondaryPhone String?
  email          String?
  address        String?
  tickets        Ticket[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
}

model Ticket {
  id                    String             @id @default(uuid())
  ticketNumber          String             @unique // Unique identifier, e.g., EQ001
  customerId            String?
  customer              Customer?          @relation(fields: [customerId], references: [id])
  currentStage          String             // "ENQUIRY" | "REFILLING" | "SERVICES" | "COMPLETED"
  currentStatus         String             // "PENDING" | "ASSIGNED" | "IN_PROGRESS" | "COMPLETED"
  
  // Core Equipment Fields (for refilling/services stages)
  itemDescription       String?
  serialNumber          String?            // Unique Cylinder Number
  capacity              String?            // e.g. "2 Kg", "4.5 Kg", "9 Kg"
  extinguisherType      String?            // e.g. "CO2", "DCP", "Water", "Foam"
  
  // Enquiry Specific Fields
  requirementCategory   String?            // "CCTV" | "New Fire Extinguisher" | "Refilling" etc.
  enquirySource         String?            // "Existing Customers" | "Social Media" etc.
  requirementDetails    String?            // Requirement description
  
  // Enquiry Follow Ups & Scheduled dates
  requestedDeliveryDate DateTime?
  followUpDate          DateTime?
  latestFollowUpNotes   String?
  followUps             TicketFollowUp[]
  
  // Delivery & AMC fields
  deliveredDate         DateTime?
  amcYears              Int?               // 1 to 10 years
  amcDate               DateTime?          // calculated as deliveredDate + amcYears
  
  // Field visit & assignment fields
  scheduledVisitDate    DateTime?
  adminNotes            String?
  technicianNotes       String?
  locationCoordinates   String?
  assignmentType        String?            @default("DELIVERY")
  
  // Serialized JSON dynamic fields for different client needs
  stageData             String?            // Serialized JSON for dynamic fields
  
  assignments           TicketAssignment[]
  history               TicketHistory[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?
}

model TicketFollowUp {
  id        String    @id @default(uuid())
  ticketId  String
  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  remarks   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model TicketAssignment {
  id          String    @id @default(uuid())
  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  status      String    // "ASSIGNED" | "COMPLETED"
  notes       String?
  deletedAt   DateTime?

  @@unique([ticketId, employeeId]) // An employee can only be assigned to a ticket once
}

model TicketHistory {
  id          String    @id @default(uuid())
  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedById String
  changedBy   Employee  @relation(fields: [changedById], references: [id])
  fromStage   String?
  toStage     String?
  fromStatus  String?
  toStatus    String?
  remarks     String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
}
